// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

enum Provider {
  GOOGLE
  GITHUB
}

enum MessageRole {
  user
  assistant
}

// user Model
model User {
  id         String  @id @default(uuid()) @db.Uuid
  clerkId    String    @unique @db.VarChar(200)  
  name       String  @db.VarChar(190)
  email      String  @unique @db.VarChar(190)
  provider   Provider  @default(GOOGLE)
  profileUrl String? @db.VarChar(400)
  role       Role    @default(user)

  isActive   Boolean    @default(true)
  created_at DateTime   @default(now())
  updated_at DateTime   @default(now()) @updatedAt
  categories Category[]
  websites   website[]
  githubRepos GithubRepo[]
  chatsSessions ChatSession[]

}

// category model
model Category {
  id          String  @id @default(uuid()) @db.Uuid
  slug        String  @unique @db.VarChar(100)
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(500)
  icon        String? @db.VarChar(200)
  color       String? @db.VarChar(50)

  isActive   Boolean   @default(true)
  createdBy  String    @db.Uuid
  user       User      @relation(fields: [createdBy], references: [id])
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  websites   website[]
}

// website model
model website {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(100)
  title       String   @db.VarChar(200)
  description String?  @db.VarChar(1000)
  url         String   @db.VarChar(200)
  imageUrl       String?  @db.VarChar(200)
  iconUrl        String?  @db.VarChar(200)
  keywords    String[] @db.VarChar(500)
  tags        String[] @db.VarChar(200)
  provider    String?  @db.VarChar(100)
  author      String?  @db.VarChar(100)
  isActive    Boolean  @default(true)

  sourceType  String?  @db.VarChar(50)
  scrapedData Json?    @db.JsonB

  categoryId String   @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  created_by  String @db.Uuid
  createdUser User   @relation(fields: [created_by], references: [id])

  githubRepo  GithubRepo[]
}


model GithubRepo {
  id          String   @id @default(uuid()) @db.Uuid
  repoId      Int      @unique 
  username    String   @db.VarChar(100)  
  repoName    String   @db.VarChar(200) 
  description String?  @db.VarChar(1000)
  url         String   @db.VarChar(255) 
  language    String?  @db.VarChar(50)
  topics      String[] @db.VarChar(100)

  isActive    Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  created_by  String @db.Uuid
  createdUser User   @relation(fields: [created_by], references: [id])

  websiteId   String?  @unique @db.Uuid
  website     website? @relation(fields: [websiteId], references: [id])

  @@index([username])
}

// Chat Session model
model ChatSession {
  id    String  @id @default(uuid()) @db.Uuid
  title String? @db.VarChar(200)

  userId  String? @db.Uuid
  user    User?   @relation(fields: [userId], references: [id])

  isActive   Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  messages ChatMessage[]
}

// Chat Message model
model ChatMessage {
  id      String      @id @default(uuid()) @db.Uuid
  role    MessageRole
  content String      @db.Text

  inputTokens  Int? @default(0)
  outputTokens Int? @default(0)
  totalTokens  Int? @default(0)


  citations Json? @db.JsonB // [{ websiteId, title, url }]

  // any extra data (model name, latency, etc.)
  metadata Json? @db.JsonB

  timestamp  DateTime @default(now())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt


  sessionId String      @db.Uuid
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

